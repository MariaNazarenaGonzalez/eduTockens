# Backend Secret — template (NO completar con valores reales aquí)
# Copiar a backend-secret.yaml y completar los valores antes de deployar.
apiVersion: v1
kind: Secret
metadata:
  name: backend-secret
  namespace: apps
  labels:
    app: backend
type: Opaque
stringData:
  JWT_SECRET: "{{ JWT_SECRET }}"
  AUTHORITY_PRIVATE_KEY: "{{ AUTHORITY_PRIVATE_KEY }}"
  AUTHORITY_PUBLIC_KEY: "{{ AUTHORITY_PUBLIC_KEY }}"